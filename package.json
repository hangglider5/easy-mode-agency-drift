{
  "name": "web-mvp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api \"vite\" \"tsx watch src/server/index.ts\"",
    "build": "tsc -b --pretty false && vite build && tsup src/server/index.ts --format esm --platform node --out-dir dist/server --external better-sqlite3 && cp src/server/db/schema.sql dist/server/schema.sql",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "record:demo": "node scripts/record-demo-master.mjs",
    "video:studio": "remotion studio video/index.ts",
    "video:render": "remotion render video/index.ts EasyModeRoughCut artifacts/demo-video/rough-cut-v1.mp4",
    "smoke:models": "vitest run tests/integration/model-smoke.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.47.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@remotion/captions": "4.0.495",
    "@remotion/cli": "4.0.495",
    "@remotion/media": "4.0.495",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "remotion": "4.0.495",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
